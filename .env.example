# AWS Configuration
# Copy this file to .env and fill in your credentials from your AWS account

# Your AWS Access Key ID (get from IAM console)
AWS_ACCESS_KEY_ID=your-access-key-id-here

# Your AWS Secret Access Key (get from IAM console)
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here

# AWS Region (default: us-east-1)
AWS_DEFAULT_REGION=us-east-1

# Optional: CloudFormation Stack Configuration
STACK_NAME=healthcare-waveform-pipeline
STACK_REGION=us-east-1

# Optional: S3 and DynamoDB configuration
DYNAMODB_TABLE_NAME=WaveformRecords
ATHENA_DATABASE=healthcare_waveforms
ATHENA_WORKGROUP=healthcare-workgroup
